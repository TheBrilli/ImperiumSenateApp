{
  "expo": {
    "name": "Imperium Senate",
    "slug": "imperium-senate-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1A0B2E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.imperium.senate",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A0B2E"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}